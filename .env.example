# IntentGate install configuration.
# install.sh / install.ps1 fill the secret values for you the first time.
# You only need to edit the ones marked "SET THIS" for a production deploy.

# Pin the product version (both gateway and console use this tag).
IMAGE_TAG=1.6.2

# --- Secrets (auto-generated by the installer if left blank) ---
POSTGRES_PASSWORD=
INTENTGATE_MASTER_KEY=
INTENTGATE_ADMIN_TOKEN=
AUTH_SECRET=

# --- Where things listen ---
# Gateway is bound to localhost by default so only this host can reach it.
# Put a reverse proxy in front for remote access. Use 0.0.0.0 to expose it.
GATEWAY_BIND=127.0.0.1
# Console is exposed on all interfaces so you can open it from your laptop.
CONSOLE_BIND=0.0.0.0

# The public URL people use for the gateway (shown in the console).
INTENTGATE_PUBLIC_GATEWAY_URL=http://localhost:8080

# --- Your real tool server (where the gateway forwards ALLOWED calls) ---
# Leave blank for the first bring-up; set it when you route a real agent.
INTENTGATE_UPSTREAM_URL=

# --- Licensing (enables Pro features; blank runs OSS-equivalent) ---
INTENTGATE_LICENSE_KEY=

# --- Sign-in ---
# "mock" lets you log in instantly for the first smoke test.
# PRODUCTION: SET THIS to "oidc", point it at Entra, and set AUTH_URL to your
# real https hostname (see the runbook, "Accessing the console").
AUTH_PROVIDER=mock
# SET THIS behind a reverse proxy, e.g. https://intentgate.yourcompany.internal
AUTH_URL=
